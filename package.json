{
  "name": "clamaco-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend && node -e \"require('fs').cpSync('frontend/dist','backend/public',{recursive:true,force:true})\"",
    "start": "npm run start --prefix backend"
  },
  "dependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^0.5.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-slow-down": "^3.0.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
